{
  "name": "yabble/laravel-convert-case-middleware",
  "description": "Convert request and response keys to and from camel and snake case.",
  "type": "library",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^12|^13",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11|^12|^13"
  },
  "license": "MIT",
  "authors": [
    {
      "name": "Tom Lerendu",
      "email": "tom.lerendu@gmail.com"
    }
  ],
  "autoload": {
    "psr-4": {
